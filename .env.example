# AlphaScan v0.5 Environment Configuration
# Copy this file to .env and fill in your credentials

# REQUIRED - Fill these in before running
CENSYS_API_ID=your_censys_api_id
CENSYS_API_SECRET=your_censys_api_secret
GITHUB_TOKEN=your_github_token
GROQ_API_KEY=your_groq_api_key
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# OPTIONAL - Override defaults
SCAN_INTERVAL=300
MAX_KEYS_PER_REPORT=50
DEBUG=false
LOG_LEVEL=INFO

# v0.5 - Autonomous Mode
AUTONOMOUS_MODE=true
AUTO_PUSH_GITHUB=true
ALLOW_AUTO_RESTART=true
AUTO_PIVOT_THRESHOLD=0.15
MAX_DECISION_LOG=1000

# v0.5 - Detection Toggles
ENABLE_SSH_DETECTION=true
ENABLE_CRYPTO_DETECTION=true
ENABLE_API_DETECTION=true

# v0.5 - Verification
VERIFICATION_TIMEOUT=5
ENABLE_ETHERSCAN_CHECK=true
ETHERSCAN_API_KEY=your_etherscan_api_key
